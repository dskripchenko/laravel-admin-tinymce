{
    "name": "dskripchenko/laravel-admin-tinymce",
    "description": "Альтернативный WYSIWYG-движок (TinyMCE) для dskripchenko/laravel-admin.",
    "type": "library",
    "keywords": [
        "laravel",
        "admin",
        "wysiwyg",
        "tinymce",
        "rich-text",
        "editor",
        "dskripchenko"
    ],
    "homepage": "https://github.com/dskripchenko/laravel-admin-tinymce",
    "license": "MIT",
    "authors": [
        {
            "name": "Denis Skripchenko",
            "email": "denskrp90@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/dskripchenko/laravel-admin-tinymce/issues",
        "source": "https://github.com/dskripchenko/laravel-admin-tinymce"
    },
    "require": {
        "php": "^8.5",
        "dskripchenko/laravel-admin": "^1.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Dskripchenko\\LaravelAdminTinymce\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dskripchenko\\LaravelAdminTinymce\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dskripchenko\\LaravelAdminTinymce\\AdminTinymceServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
